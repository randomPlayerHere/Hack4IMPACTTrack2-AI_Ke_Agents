# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment/config secrets
.env
.env.*
!.env.example

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.cache/

# Coverage / test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# Editors / IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Project data artifacts (keep directory structure, ignore contents)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Model artifacts (too large for git — download separately)
# Place these in models/ locally; see README for instructions
models/*.h5
models/*.tflite
models/*.pkl
models/*.joblib
models/*.onnx
models/*.pt
models/*.pth
models/*.ckpt
!models/.gitkeep

# Other common ML artifacts
checkpoints/
artifacts/
outputs/
logs/
