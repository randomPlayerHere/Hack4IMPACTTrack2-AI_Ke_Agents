# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment/config secrets
.env
.env.*
!.env.example

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
