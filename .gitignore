build/
dist/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# Editors / IDEs
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Project data artifacts (keep directory structure, ignore contents)
data/raw/*
!data/raw/.gitkeep
data/processed/*
